<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Anime Character Collection</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; background: #f4f7ff; color: #111; }
    .container { width: min(1000px, 95%); margin: 18px auto; }
    header { display:flex; justify-content:space-between; align-items:center; }
    h1 { margin:0; }
    .cards { display:grid; grid-template-columns: repeat(auto-fit, minmax(250px,1fr)); gap: 12px; margin-top: 20px; }
    .card { border-radius: 10px; background: white; box-shadow: 0 1px 6px rgba(0,0,0,.1); overflow:hidden; }
    .card img { width:100%; height:200px; object-fit:cover; }
    .card-body { padding:10px; }
    .meta { font-size:.88rem; color:#555; margin-top:4px; }
    .btn { padding:8px 12px; text-decoration:none; background:#3b82f6; color:white; border-radius:6px; }
    .empty { margin-top: 28px; padding: 18px; background: #eaf0ff; border: 1px solid #cad7ff; border-radius: 8px; }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <div>
        <h1>Anime Character Collection</h1>
        <p>Create and store your custom anime character cards.</p>
      </div>
      <a href="/create" class="btn">Create New Character</a>
    </header>

    <% if (characters.length === 0) { %>
      <div class="empty"><strong>No characters yet.</strong> Click Create New Character to add one.</div>
    <% } else { %>
      <div class="cards">
        <% characters.forEach((c) => { %>
          <div class="card">
            <img src="<%= c.image_url %>" alt="<%= c.name %> avatar" onerror="this.src='https://via.placeholder.com/400x200?text=No+image'" />
            <div class="card-body">
              <h3><%= c.name %></h3>
              <p><%= c.description %></p>
              <% if (c.personality) { %><div class="meta"><strong>Personality:</strong> <%= c.personality %></div><% } %>
              <% if (c.traits) { %><div class="meta"><strong>Traits:</strong> <%= c.traits %></div><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
